# Kopieer dit bestand naar .env en pas de waarden aan.
# Alle variabelen zijn optioneel; zonder .env draait de server met de defaults.

# Poort en bind-adres
PORT=3000
HOST=0.0.0.0

# Pad waarop Krone-pushes binnenkomen
WEBHOOK_PATH=/krone/push

# Basic Auth — vul beide in om authenticatie te activeren.
# Gebruik dezelfde gebruikersnaam/wachtwoord als geconfigureerd in het Krone DataCenter.
#BASIC_AUTH_USER=
#BASIC_AUTH_PASSWORD=

# Zet op true om alleen requests van de officiële Krone push-IP's te accepteren
# (85.236.61.180 en 85.236.61.181). Uit laten tijdens lokaal testen.
ENFORCE_IP_ALLOWLIST=false

# Alleen op true zetten als de server achter een reverse proxy (nginx/Caddy)
# draait; het client-IP wordt dan uit X-Forwarded-For gelezen. Bij een direct
# aan internet hangende server UIT laten, anders is de IP-allowlist te omzeilen.
TRUST_PROXY=false

# --- Dagelijks rapport per e-mail ---

# Welke trailers volgen in het rapport (kenteken, VH_ID, asset-naam of box-ID),
# meerdere scheiden met komma's, bijv. TRACKED_VEHICLES=OL-12-XX,OL-34-YY
# Leeg laten = alle trailers waarvoor data binnenkomt.
#TRACKED_VEHICLES=

# Wanneer het rapport wordt gestuurd (cron-formaat, in TIMEZONE).
# "0 7 * * *" = elke dag om 07:00. Leeg laten = geen automatisch rapport.
#REPORT_CRON=0 7 * * *
TIMEZONE=Europe/Amsterdam

# Na hoeveel uur zonder update een trailer als "geen recente update" wordt gemeld
STALE_AFTER_HOURS=24

# SMTP-instellingen voor het versturen van de mail.
# Zonder SMTP_HOST wordt het rapport naar de console geprint (dry-run).
#SMTP_HOST=smtp.office365.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASSWORD=
#MAIL_FROM=
#MAIL_TO=rutger@vanrees.nl

# Map waar de laatst bekende posities worden opgeslagen
DATA_DIR=data
