# Kopieer dit bestand naar .env en pas de waarden aan.
# Alle variabelen zijn optioneel; zonder .env draait de server met de defaults.

# Poort en bind-adres
PORT=3000
HOST=0.0.0.0

# Pad waarop Krone-pushes binnenkomen
WEBHOOK_PATH=/krone/push

# Basic Auth — vul beide in om authenticatie te activeren.
# Gebruik dezelfde gebruikersnaam/wachtwoord als geconfigureerd in het Krone DataCenter.
#BASIC_AUTH_USER=
#BASIC_AUTH_PASSWORD=

# Zet op true om alleen requests van de officiële Krone push-IP's te accepteren
# (85.236.61.180 en 85.236.61.181). Uit laten tijdens lokaal testen.
ENFORCE_IP_ALLOWLIST=false

# Alleen op true zetten als de server achter een reverse proxy (nginx/Caddy)
# draait; het client-IP wordt dan uit X-Forwarded-For gelezen. Bij een direct
# aan internet hangende server UIT laten, anders is de IP-allowlist te omzeilen.
TRUST_PROXY=false

TIMEZONE=Europe/Amsterdam

# --- Klanten ---

# Per klant een genummerd blok: NAME is de naam exact zoals in het TMS
# (RM_Relation.Name), MAIL zijn de ontvangers (meerdere scheiden met komma's).
# De query filtert automatisch op deze klanten via de @customers-placeholder.
CUSTOMER_1_NAME=Kramp Groep B.V.
CUSTOMER_1_MAIL=rutger@vanrees.nl

#CUSTOMER_2_NAME=
#CUSTOMER_2_MAIL=

# --- ETA-mail ---

# MSSQL-database voor dynamische trailer/bestemming-combinaties.
# De query in ETA_QUERY_FILE bepaalt welke ETA-mails er worden gestuurd
# (zie eta-query.sql voor het kolomcontract).
#MSSQL_SERVER=
#MSSQL_DATABASE=
#MSSQL_USER=
#MSSQL_PASSWORD=
# Zet op true voor een TLS-versleutelde verbinding (verplicht bij Azure SQL)
MSSQL_ENCRYPT=false
#ETA_QUERY_FILE=eta-query.sql

# Fallback zonder database: één vaste trailer + bestemming
#ETA_VEHICLE=OT-84-LL
#ETA_DESTINATION_ADDRESS=Siemensstraße 1, 96129 Strullendorf, DE

# Optioneel: vaste coördinaten van de bestemming (slaat geocoding over)
#ETA_DESTINATION_LAT=49.8450569
#ETA_DESTINATION_LON=10.9540135

# De planner checkt elke 5 minuten. Een zending geldt als vertraagd zodra de
# verwachte aankomst meer dan dit aantal minuten na de afgesproken tijd ligt.
LATE_THRESHOLD_MINUTES=15

# Na de eerste vertragingsmail volgt pas een nieuwe mail als de vertraging met
# minstens dit aantal minuten oploopt (voorkomt spam bij oplopende vertraging).
LATE_STEP_MINUTES=30

# Vast tijdstip voor ritten ZONDER afgesproken tijd en voor de env-fallback
# (cron-formaat met 5 velden, in TIMEZONE). Leeg laten = geen vaste run.
#ETA_CRON=0 6 * * 1-5

# SMTP-instellingen voor het versturen van de mail.
# Zonder SMTP_HOST wordt het rapport naar de console geprint (dry-run).
#SMTP_HOST=smtp.office365.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASSWORD=
#MAIL_FROM=
#MAIL_TO=rutger@vanrees.nl

# Map waar de laatst bekende posities worden opgeslagen
DATA_DIR=data

# Zet op false om niet elke ontvangen push te loggen (aan te raden bij een
# grote vloot; scheelt duizenden logregels per dag)
LOG_PUSHES=true
